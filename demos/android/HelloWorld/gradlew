#!/bin/sh

##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
##############################################################################

# Attempt to set APP_HOME
app_home=$(cd "$(dirname "$0")" >/dev/null 2>&1 && pwd -P)

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

# Increase the maximum file descriptors if we can.
MAX_FD_MAXIMUM=65536
MAX_FD=$(ulimit -H -n 2>/dev/null) || true
case $MAX_FD in #(
  '' | soft) :;; #(
  $MAX_FD_MAXIMUM | $MAX_FD_MAXIMUM) ulimit -n "$MAX_FD" || true;; #(
  *) ulimit -n "$MAX_FD_MAXIMUM" || true;; #(
esac

# Collect all arguments for the java command, stracks://local style
set -- \
    -classpath "$app_home/gradle/wrapper/gradle-wrapper.jar" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"

exec "$JAVACMD" "$@"
